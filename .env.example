# zo2api environment variables

# Server port
PORT=8000

# Zo access token(s). Use ZO_ACCESS_TOKEN (letter O). Z0_ACCESS_TOKEN (zero) is also supported.
# Supported examples:
# ZO_ACCESS_TOKEN=XXX
# ZO_ACCESS_TOKEN=XXX,yyy,ZZz
# ZO_ACCESS_TOKEN=[xxx,yyy,Zzz]
# ZO_ACCESS_TOKEN=["XXX","yyy","zZZ"]
# ZO_ACCESS_TOKEN=["XXX"，"yyy"，"zZZ"]
ZO_ACCESS_TOKEN=XXX

# Proxy authentication key used by clients in the Authorization header.
# PROXY_API_KEY=sk-691a145ffc331a4540a4abd8e920ef835cfa39483d5141b5

# Optional behavior flags. Set to true to enable.
PROXY_PROMPT_OVERRIDE=false
PROXY_OUTPUT_SANITIZE=false
